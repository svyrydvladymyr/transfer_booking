<!DOCTYPE HTML>
<html lang="en">
<head>
    <%- include("./parts/head.ejs") %>
</head>
<body>
    <%- include("./parts/header.ejs") %>    
    <div class="main_body">
        <% if (DATA.permission.permissionAuthorization === '0') { %>        
            <div class="no_user">
                <p><%=DATA.langPack.autoriz_info %></p>
                <div>
                    <a href="/google"><img src="img/google.png" alt="google" title="GOOGLE"></a>
                    <a href="/facebook"><img src="img/facebook.png" alt="facebook" title="FACEBOOK"></a>
                </div>
            </div>
        <% } %>        
        <% if (DATA.permission.permissionAuthorization === '1') { %>
            <div class="user_wrap">
                <img src="<%=DATA.user.ava %>">
                <p><%=DATA.user.surname %> <%=DATA.user.name %></p>
                <p onclick="exit()" class="exit"><%=DATA.langPack.exit %></p>
                <% if (DATA.permission.permissionRules === '1') { %> 
                    <div class="modal_wrap"></div>                
                <% } %>                 
            
                <% if (DATA.permission.permissionRules === '0') { %>        

                    <p>autorised USER</p>
                
                <% } %>           
                <% if (DATA.permission.permissionRules === '1') { %> 
                    <div class="tab_person">
                        <div class="tabs">
                            <p class="tab tab_active" onclick="tabs(0)">Бронювання</p>
                            <p class="tab" onclick="tabs(1)">Повідомлення</p>
                            <p class="tab" onclick="tabs(2)">Міста</p>
                            <p class="tab" onclick="tabs(3)">Маршрути</p>
                        </div>
                        <div class="tab_bodys">
                            <div class="body body_active">

                                
                                <div class="orders_list"></div>
                            </div>
                            <div class="body">


                                <div class="feedbacks_list"></div>
                            </div>
                            <div class="body">                                
                                <p onclick="showModal('townAdd')" class="add_point">Додати місто</p>
                                <div class="tawns_list"></div>
                            </div>
                            <div class="body">
                                <p onclick="showModal('transferAdd')" class="add_point">Додати маршрут</p>
                                <div class="transfers_list"></div>
                            </div>
                        </div>
                    </div>                
                <% } %>   
            </div> 
        <% } %> 


    </div>
    <%- include("./parts/footer.ejs") %>
    <script src="./js/lang.js"></script>
    <script src="./js/data.js"></script>
    <script src="./js/js.js"></script>
    <script src='./js/icon.js'></script>
    <% if (DATA.permission.permissionAuthorization === '1') { %>
        <% if (DATA.permission.permissionRules === '1') { %> 
            <script>
                loadTownsList();  
                loadTransfersList();  
            </script>                      
        <% } %>   
    <% } %> 
</body>